PORT=3000
API_KEY=sua_chave_de_api_aqui_mude_isso
NODE_ENV=development

# Evolution API (envio de mensagens WhatsApp)
EVOLUTION_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_evolution_api_key
EVOLUTION_INSTANCE=nome_da_instancia

# Microvox API (extração de dados)
MICROVOX_URL=https://sua-instancia.microvox.com.br
MICROVOX_API_KEY=sua_microvox_api_key
# Autenticação alternativa por usuário/senha (se aplicável):
# MICROVOX_USERNAME=seu_usuario
# MICROVOX_PASSWORD=sua_senha

# Relatórios automáticos
# Números de WhatsApp que receberão o relatório diário (separados por vírgula)
REPORT_RECIPIENTS=5511999999999,5511888888888
# Horário do disparo diário no fuso de Brasília (HH:MM)
REPORT_TIME=08:00
